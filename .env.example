# Database (Neon PostgreSQL for Cloudflare / local for dev)
# Cloudflare: DATABASE_URL="postgresql://user:pass@ep-xxx.us-west-2.aws.neon.tech/salon_hair?sslmode=require"
# Local:      DATABASE_URL="postgresql://postgres:postgres@localhost:5432/salon_hair"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/salon_hair"

# AWS S3 (for file uploads) — or Cloudflare R2 with S3-compatible endpoint
AWS_PROFILE=your_aws_profile
AWS_REGION=us-west-2
AWS_BUCKET_NAME=your-bucket-name
AWS_FOLDER_PREFIX=your-folder-prefix/

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET="your-nextauth-secret-here"

# Optional: VNPay (for payment integration)
# VNP_TMN_CODE=your_tmn_code
# VNP_HASH_SECRET=your_hash_secret
# VNP_URL=https://sandbox.vnpayment.vn/v2/paymentv2/vpcpay.html

# Optional: MoMo (for payment integration)
# MOMO_PARTNER_CODE=your_partner_code
# MOMO_ACCESS_KEY=your_access_key
# MOMO_SECRET_KEY=your_secret_key
# MOMO_URL=https://test-payment.momo.vn/v2/gateway/api/create

# Shipping (defaults: 30000 VND, free over 1000000 VND)
# SHIPPING_FEE=30000
# FREE_SHIPPING_THRESHOLD=1000000

# Affiliate / referral (default: 10%, min payout 200000 VND)
# DEFAULT_COMMISSION_RATE=10
# MIN_PAYOUT=200000

# Rate limiting (defaults: API 60/min, Auth 10/min)
# RATE_LIMIT_API_MAX=60
# RATE_LIMIT_API_INTERVAL_MS=60000
# RATE_LIMIT_AUTH_MAX=10
# RATE_LIMIT_AUTH_INTERVAL_MS=60000

# SMTP (for forgot-password email)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM_NAME=SALON HAIR SYSTEM
# SMTP_FROM_EMAIL=your-email@gmail.com
